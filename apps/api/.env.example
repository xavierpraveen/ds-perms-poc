# ─── Database ───────────────────────────────────────────────────────────────
# Supabase → Project Settings → Database → Connection string (URI)
# Use the POOLED (pgBouncer) connection on port 6543 in production.
# For local development you can point both vars to the same direct URL.
DATABASE_URL=postgresql://postgres:[PASSWORD]@[PROJECT].supabase.co:6543/postgres?pgbouncer=true

# Direct (non-pooled) connection — required by Prisma for migrations.
# Supabase → Project Settings → Database → Connection string (URI) → port 5432
DIRECT_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres

# ─── Clerk ──────────────────────────────────────────────────────────────────
# Clerk dashboard → API Keys → Secret key  (sk_test_… or sk_live_…)
CLERK_SECRET_KEY=sk_test_

# ─── Server ─────────────────────────────────────────────────────────────────
# Port the NestJS API listens on. Default: 3001
PORT=3001

# Node environment
NODE_ENV=development

# Comma-separated list of allowed CORS origins.
# Add your frontend URL here. Default: http://localhost:3000
CORS_ORIGINS=http://localhost:3000
