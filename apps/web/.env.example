# ─── Clerk ──────────────────────────────────────────────────────────────────
# Clerk dashboard → API Keys → Publishable key  (pk_test_… or pk_live_…)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_

# Clerk dashboard → API Keys → Secret key  (sk_test_… or sk_live_…)
CLERK_SECRET_KEY=sk_test_

# ─── Clerk Routes ────────────────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# ─── API ─────────────────────────────────────────────────────────────────────
# Base URL of the NestJS API. Local: http://localhost:3001
# Production: your deployed API URL (no trailing slash)
NEXT_PUBLIC_API_URL=http://localhost:3001/api
